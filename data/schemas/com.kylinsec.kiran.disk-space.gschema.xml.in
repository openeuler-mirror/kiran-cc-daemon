<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="@PROJECT_NAME@">
  <schema id="com.kylinsec.kiran.disk-space" path="/com/kylinsec/kiran/disk-space/">
    <key name="free-percent-notify" type="d">
      <default>0.05</default>
      <summary>Free percentage notify threshold</summary>
      <description>Percentage free space threshold for initial warning of low disk space. Valid range: [0, 1). Value 0 means notify when any space is used.</description>
    </key>
    <key name="free-percent-notify-again" type="d">
      <default>0.01</default>
      <summary>Subsequent free percentage notify threshold</summary>
      <description>Specify the percentage that the free disk space should reduce by before issuing a subsequent warning. Valid range: [0, 1).</description>
    </key>
    <key name="free-size-gb-no-notify" type="i">
      <default>2</default>
      <summary>If more than this many GiB remain free, do not notify (absolute floor)</summary>
      <range min="0" max="1048576"/>
    </key>
    <key name="min-notify-period" type="i">
      <default>10</default>
      <summary>Minimum minutes between repeat notifications for the same mount</summary>
      <range min="1" max="10080"/>
    </key>
    <key name="ignore-paths" type="as">
      <default>[]</default>
      <summary>Mount paths excluded from low-disk checks</summary>
    </key>
    <key name="check-interval-seconds" type="i">
      <default>60</default>
      <summary>Periodic mount check interval</summary>
      <range min="10" max="86400"/>
    </key>
  </schema>
</schemalist>
